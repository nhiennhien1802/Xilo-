# Đổi tên file này thành .env.local rồi điền giá trị thật từ Supabase Dashboard
# (Settings -> API) trước khi chạy "npm run dev"

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chỉ cần khi chạy script import dữ liệu mẫu (scripts/import-hsk1.mjs) ở local
# KHÔNG khai báo biến này trên Vercel
SUPABASE_SERVICE_ROLE_KEY=
